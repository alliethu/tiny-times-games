{
  "expo": {
    "name": "Tiny Times Games",
    "slug": "tiny-times-games",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tinytimesgames",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tinytimes.games"
    },
    "android": {
      "package": "com.tinytimes.games",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
