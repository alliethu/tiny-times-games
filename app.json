{
  "expo": {
    "name": "Tiny Times Games",
    "slug": "tiny-times-games",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tinytimesgames",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFBFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tinytimes.games"
    },
    "android": {
      "package": "com.tinytimes.games",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
